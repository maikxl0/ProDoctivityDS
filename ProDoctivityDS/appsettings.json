{
  "UseInMemoryDatabase": false,
  "ConnectionStrings": {
    "ConnectionDb": "Server=localhost;Database=ProDoctivityDS;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "AppData": {
    "BasePath": "App_Data"
  },
  "Persistence": {
    "ConfigurationFilePath": "App_Data/stored-configuration.json",
    "DataProtectionKeysPath": "App_Data/DataProtectionKeys"
  },
  "FileStorage": {
    "BasePath": "Storage"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://prodoctivity-frontend.onrender.com"
    ]
  }
}
